# ─────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────

### Registro Cliente
POST {{baseUrl}}/auth/register/client
Content-Type: application/json

{
  "first_name": "Carlos",
  "last_name": "Lopez",
  "age": 25,
  "email": "carlos@test.com",
  "password": "password123"
}

### Registro Rider
POST {{baseUrl}}/auth/register/rider
Content-Type: application/json

{
  "first_name": "Juan",
  "last_name": "Rider",
  "age": 28,
  "email": "juan@test.com",
  "password": "password123",
  "license_plate": "P-001XYZ",
  "vehicle_type": "MOTO",
  "vehicle_model": "Honda CB150",
  "zone": "ZONA_1"
}

### Login Cliente
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "carlos@test.com",
  "password": "password123"
}

### Login Rider
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "juan@test.com",
  "password": "password123"
}

### Login Admin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@flashdelivery.com",
  "password": "password"
}

### Registro duplicado (debe fallar 409)
POST {{baseUrl}}/auth/register/client
Content-Type: application/json

{
  "first_name": "Carlos",
  "last_name": "Lopez",
  "age": 25,
  "email": "carlos@test.com",
  "password": "password123"
}

### Login incorrecto (debe fallar 401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "carlos@test.com",
  "password": "wrongpassword"
}

# ORDENES

### Crear pedido (Cliente)
POST {{baseUrl}}/orders
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "origin": "prueba1000: Zona 10, Ciudad de Guatemala",
  "destination": "Zona 1, Ciudad de Guatemala",
  "description": "Caja pequeña con documentos",
  "distanceKm": 5.2,
  "zone": "ZONA_1"
}

### VER PERFIL
GET {{baseUrl}}/auth/me
Authorization: Bearer {{tokenCliente}}

### Actualizar foto de perfil (Cliente)
PATCH {{baseUrl}}/auth/photo
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "profile_photo": "https://i.pravatar.cc/300?img=1"
}


### Ver pedidos disponibles (Rider)
GET {{baseUrl}}/orders/available
Authorization: Bearer {{tokenRider}}

### Aceptar pedido (Rider)
PATCH {{baseUrl}}/orders/18/accept
Authorization: Bearer {{tokenRider}}

### Marcar entregado (Rider)
PATCH {{baseUrl}}/orders/18/deliver
Authorization: Bearer {{tokenRider}}

### historial de los pedidos del rider 
GET {{baseUrl}}/orders/rider/mine
Authorization: Bearer {{tokenRider}}

### pedido que tiene activo el rider
GET {{baseUrl}}/orders/rider/active
Authorization: Bearer {{tokenRider}}


### Calificar pedido (Cliente)
POST {{baseUrl}}/orders/9/rating
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "stars": 5,
  "comment": "Excelente servicio, muy rápido y profesional."
}

### Mis pedidos como Cliente
GET {{baseUrl}}/orders/mine
Authorization: Bearer {{tokenCliente}}

### Ver pedido por ID
GET {{baseUrl}}/orders/1
Authorization: Bearer {{tokenCliente}}















# ADMIN
### Ver todos los usuarios
GET {{baseUrl}}/admin/users
Authorization: Bearer {{tokenAdmin}}

### Ver riders pendientes de verificación
GET {{baseUrl}}/admin/riders/pending
Authorization: Bearer {{tokenAdmin}}

### Verificar rider
PATCH {{baseUrl}}/admin/riders/13/verify
Authorization: Bearer {{tokenAdmin}}

### Reporte — Resumen de pedidos
GET {{baseUrl}}/admin/reports/orders
Authorization: Bearer {{tokenAdmin}}

### Reporte — Ganancias plataforma
GET {{baseUrl}}/admin/reports/earnings
Authorization: Bearer {{tokenAdmin}}

### Reporte — Riders más activos
GET {{baseUrl}}/admin/reports/riders
Authorization: Bearer {{tokenAdmin}}

### Ver ganancias de un rider específico (Admin)
GET {{baseUrl}}/earnings/rider/13
Authorization: Bearer {{tokenAdmin}}

### Ver resumen global de ganancias (Admin)
GET {{baseUrl}}/earnings/summary
Authorization: Bearer {{tokenAdmin}}




# ─────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────

### Ver todas mis notificaciones
GET {{baseUrl}}/notifications
Authorization: Bearer {{tokenCliente}}

### Ver solo notificaciones no leídas
GET {{baseUrl}}/notifications/unread
Authorization: Bearer {{tokenCliente}}

### Marcar notificación como leída
PATCH {{baseUrl}}/notifications/17/read
Authorization: Bearer {{tokenCliente}}

### Marcar todas las notificaciones como leídas
PATCH {{baseUrl}}/notifications/read-all
Authorization: Bearer {{tokenCliente}}

# Notificaciones del rider
# ─────────────────────────────────────────
# NOTIFICATIONS RIDER
# ─────────────────────────────────────────

### Ver todas mis notificaciones (Rider)
GET {{baseUrl}}/notifications
Authorization: Bearer {{tokenRider}}

### Ver notificaciones no leídas (Rider)
GET {{baseUrl}}/notifications/unread
Authorization: Bearer {{tokenRider}}

### Marcar una notificación como leída (Rider)
PATCH {{baseUrl}}/notifications/1/read
Authorization: Bearer {{tokenRider}}

### Marcar todas las notificaciones como leídas (Rider)
PATCH {{baseUrl}}/notifications/read-all
Authorization: Bearer {{tokenRider}}



